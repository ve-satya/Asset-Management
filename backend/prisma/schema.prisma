generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProductType {
  id                 Int       @id @default(autoincrement())
  displayName        String    @map("display_name")
  displayPluralName  String    @map("display_plural_name")
  apiName            String    @unique @map("api_name")
  apiPluralName      String    @map("api_plural_name")
  category           String    @map("category")
  assetType          String    @map("asset_type")
  assetCategory      String    @map("asset_category")
  description        String?
  parentId           Int?      @map("parent_id")
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  parent   ProductType?  @relation("Hierarchy", fields: [parentId], references: [id])
  children ProductType[] @relation("Hierarchy")
  assets   Asset[]
  products Product[]
  fields   ProductTypeField[]

  @@map("product_types")
}

model Product {
  id             Int      @id @default(autoincrement())
  name           String
  productTypeId  Int      @map("product_type_id")
  manufacturerId Int?     @map("manufacturer_id")
  partNo         String?  @map("part_no")
  cost           Float?
  isActive       Boolean  @default(true) @map("is_active")
  description    String?
  images         Json     @default("[]")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  productType  ProductType   @relation(fields: [productTypeId], references: [id])
  manufacturer Manufacturer? @relation(fields: [manufacturerId], references: [id])
  assets       Asset[]

  @@map("products")
}

model Vendor {
  id            Int      @id @default(autoincrement())
  name          String
  currency      String   @default("USD")
  contactPerson String?  @map("contact_person")
  email         String?
  phone         String?
  fax           String?
  website       String?
  isActive      Boolean  @default(true) @map("is_active")
  description   String?
  doorNumber    String?  @map("door_number")
  street        String?
  landmark      String?
  city          String?
  state         String?
  postalCode    String?  @map("postal_code")
  country       String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  assets Asset[]

  @@map("vendors")
}

model ProductTypeField {
  id                    Int      @id @default(autoincrement())
  productTypeId         Int      @map("product_type_id")
  fieldName             String   @map("field_name")
  fieldKey              String   @map("field_key")
  fieldType             String   @default("text") @map("field_type")
  required              Boolean  @default(false)
  displayOrder          Int      @default(0) @map("display_order")
  sectionName           String   @default("Details") @map("section_name")
  isInheritedToChildren Boolean  @default(true) @map("is_inherited_to_children")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  productType ProductType @relation(fields: [productTypeId], references: [id])
  values      AssetDynamicFieldValue[]

  @@unique([productTypeId, fieldKey])
  @@map("product_type_fields")
}

model SoftwareType {
  id               Int      @id @default(autoincrement())
  name             String
  description      String?
  enableCompliance Boolean  @default(false) @map("enable_compliance")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("software_types")
}

model SoftwareCategory {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("software_categories")
}

model SoftwareLicenseType {
  id                   Int      @id @default(autoincrement())
  name                 String
  manufacturerId       Int?     @map("manufacturer_id")
  trackBy              String?  @map("track_by")
  installationsAllowed String?  @map("installations_allowed")
  isPerpetual          Boolean  @default(false) @map("is_perpetual")
  isFreeLicense        Boolean  @default(false) @map("is_free_license")
  licenseOption        String?  @map("license_option")
  description          String?
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  manufacturer Manufacturer? @relation(fields: [manufacturerId], references: [id])

  @@map("software_license_types")
}

model AssetState {
  id                Int      @id @default(autoincrement())
  name              String
  description       String?
  requiresOwnership Boolean  @default(false) @map("requires_ownership")
  requiresScan      Boolean  @default(false) @map("requires_scan")
  isActive          Boolean  @default(true)  @map("is_active")
  createdAt         DateTime @default(now())  @map("created_at")
  updatedAt         DateTime @updatedAt       @map("updated_at")

  assets Asset[]

  @@map("asset_states")
}

model Manufacturer {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt      @map("updated_at")

  products             Product[]
  softwareLicenseTypes SoftwareLicenseType[]

  @@map("manufacturers")
}

model Asset {
  id                 Int       @id @default(autoincrement())
  productTypeId      Int       @map("product_type_id")
  name               String
  assetTag           String?   @map("asset_tag")
  orgSerialNumber    String?   @map("org_serial_number")
  description        String?
  partNumber         String?   @map("part_number")
  productId          Int?      @map("product_id")
  product            String?
  vendorId           Int?      @map("vendor_id")
  vendor             String?
  barcode            String?
  manufacturer       String?
  assetStateId       Int?      @map("asset_state_id")
  assetState         String?   @map("asset_state")
  assignedUserId     Int?      @map("assigned_user_id")
  user               String?
  departmentId       Int?      @map("department_id")
  department         String?
  associatedAssetId  Int?      @map("associated_asset_id")
  associatedToAssets String?   @map("associated_to_assets")
  retainUserSiteAsAssetSite Boolean @default(false) @map("retain_user_site_as_asset_site")
  siteId             Int?      @map("site_id")
  site               String?
  region             String?
  location           String?
  isLoanable         Boolean   @default(false) @map("is_loanable")
  loanStart          DateTime? @map("loan_start")
  loanEnd            DateTime? @map("loan_end")
  comments           String?
  acquisitionDate    DateTime? @map("acquisition_date")
  expiryDate         DateTime? @map("expiry_date")
  purchaseCost       Float?    @map("purchase_cost")
  warrantyExpiryDate DateTime? @map("warranty_expiry_date")
  impactDetails      String?   @map("impact_details")
  impact             String?
  assetAudited       String?   @map("asset_audited")
  purchaseOrder      String?   @map("purchase_order")
  purchaseOrderNo    String?   @map("purchase_order_no")
  lastScanStatus     String?   @map("last_scan_status")
  lastScanTime       DateTime? @map("last_scan_time")
  scanState          String?   @map("scan_state")
  stateComments      String?   @map("state_comments")
  macAddress         String?   @map("mac_address")
  serviceTag         String?   @map("service_tag")
  domain             String?
  smbiosVersion      String?   @map("smbios_version")
  biosVersion        String?   @map("bios_version")
  biosManufacturer   String?   @map("bios_manufacturer")
  biosDate           String?   @map("bios_date")
  osName             String?   @map("os_name")
  osVersion          String?   @map("os_version")
  osBuildNumber      String?   @map("os_build_number")
  osServicePack      String?   @map("os_service_pack")
  osProductId        String?   @map("os_product_id")
  ram                String?
  virtualMemory      String?   @map("virtual_memory")
  physicalMemory     String?   @map("physical_memory")
  processors         Json?     @default("[]")
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  productType ProductType @relation(fields: [productTypeId], references: [id])
  productRef  Product?    @relation(fields: [productId], references: [id])
  vendorRef   Vendor?     @relation(fields: [vendorId], references: [id])
  stateRef    AssetState? @relation(fields: [assetStateId], references: [id])
  associatedAsset Asset?  @relation("AssociatedAsset", fields: [associatedAssetId], references: [id])
  associatedAssets Asset[] @relation("AssociatedAsset")
  dynamicFieldValues AssetDynamicFieldValue[]
  history AssetHistory[]
  parentRelationships AssetRelationship[] @relation("ParentAssetRelationship")
  relatedRelationships AssetRelationship[] @relation("RelatedAssetRelationship")
  serviceRelationships AssetServiceRelationship[]

  @@map("assets")
}

model AssetRelationship {
  id               Int      @id @default(autoincrement())
  parentAssetId    Int      @map("parent_asset_id")
  relatedAssetId   Int      @map("related_asset_id")
  relationshipType String   @map("relationship_type")
  createdBy        String?  @map("created_by")
  createdOn        DateTime @default(now()) @map("created_on")

  parentAsset  Asset @relation("ParentAssetRelationship", fields: [parentAssetId], references: [id], onDelete: Cascade)
  relatedAsset Asset @relation("RelatedAssetRelationship", fields: [relatedAssetId], references: [id], onDelete: Cascade)

  @@index([parentAssetId, relationshipType])
  @@map("asset_relationships")
}

model AssetServiceRelationship {
  id               Int      @id @default(autoincrement())
  assetId          Int      @map("asset_id")
  serviceId        Int?     @map("service_id")
  serviceName      String?  @map("service_name")
  relationshipType String   @map("relationship_type")
  createdBy        String?  @map("created_by")
  createdOn        DateTime @default(now()) @map("created_on")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, relationshipType])
  @@map("asset_service_relationships")
}

model AssetHistory {
  id         Int      @id @default(autoincrement())
  assetId    Int      @map("asset_id")
  actionType String   @map("action_type")
  changedBy  String?  @map("changed_by")
  changedOn  DateTime @default(now()) @map("changed_on")
  fieldName  String?  @map("field_name")
  oldValue   String?  @map("old_value")
  newValue   String?  @map("new_value")
  comments   String?

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, changedOn])
  @@map("asset_history")
}

model AssetDynamicFieldValue {
  id                 Int      @id @default(autoincrement())
  assetId            Int      @map("asset_id")
  productTypeFieldId Int      @map("product_type_field_id")
  value              String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  field ProductTypeField @relation(fields: [productTypeFieldId], references: [id])

  @@unique([assetId, productTypeFieldId])
  @@map("asset_dynamic_field_values")
}
