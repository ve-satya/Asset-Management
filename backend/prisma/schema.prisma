generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProductType {
  id                Int      @id @default(autoincrement())
  displayName       String   @map("display_name")
  displayPluralName String   @map("display_plural_name")
  apiName           String   @unique @map("api_name")
  apiPluralName     String   @map("api_plural_name")
  category          String   @map("category")
  assetType         String   @map("asset_type")
  assetCategory     String   @map("asset_category")
  description       String?
  parentId          Int?     @map("parent_id")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  parent   ProductType?  @relation("Hierarchy", fields: [parentId], references: [id])
  children ProductType[] @relation("Hierarchy")
  assets   Asset[]
  products Product[]

  @@map("product_types")
}

model Product {
  id             Int      @id @default(autoincrement())
  name           String
  productTypeId  Int      @map("product_type_id")
  manufacturerId Int?     @map("manufacturer_id")
  partNo         String?  @map("part_no")
  cost           Float?
  isActive       Boolean  @default(true) @map("is_active")
  description    String?
  images         Json     @default("[]")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  productType    ProductType   @relation(fields: [productTypeId], references: [id])
  manufacturer   Manufacturer? @relation(fields: [manufacturerId], references: [id])
  selectedAssets Asset[]       @relation("SelectedProduct")

  @@map("products")
}

model Vendor {
  id            Int      @id @default(autoincrement())
  name          String
  currency      String   @default("USD")
  contactPerson String?  @map("contact_person")
  email         String?
  phone         String?
  fax           String?
  website       String?
  isActive      Boolean  @default(true) @map("is_active")
  description   String?
  doorNumber    String?  @map("door_number")
  street        String?
  landmark      String?
  city          String?
  state         String?
  postalCode    String?  @map("postal_code")
  country       String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("vendors")
}

model SoftwareType {
  id               Int      @id @default(autoincrement())
  name             String
  description      String?
  enableCompliance Boolean  @default(false) @map("enable_compliance")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("software_types")
}

model SoftwareCategory {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("software_categories")
}

model SoftwareLicenseType {
  id                   Int      @id @default(autoincrement())
  name                 String
  manufacturerId       Int?     @map("manufacturer_id")
  trackBy              String?  @map("track_by")
  installationsAllowed String?  @map("installations_allowed")
  isPerpetual          Boolean  @default(false) @map("is_perpetual")
  isFreeLicense        Boolean  @default(false) @map("is_free_license")
  licenseOption        String?  @map("license_option")
  description          String?
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  manufacturer Manufacturer? @relation(fields: [manufacturerId], references: [id])

  @@map("software_license_types")
}

model AssetState {
  id                Int      @id @default(autoincrement())
  name              String
  description       String?
  requiresOwnership Boolean  @default(false) @map("requires_ownership")
  requiresScan      Boolean  @default(false) @map("requires_scan")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("asset_states")
}

model Manufacturer {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products             Product[]
  softwareLicenseTypes SoftwareLicenseType[]

  @@map("manufacturers")
}

model Asset {
  id                 Int       @id @default(autoincrement())
  productTypeId      Int       @map("product_type_id")
  name               String
  assetTag           String?   @map("asset_tag")
  orgSerialNumber    String?   @map("org_serial_number")
  description        String?
  partNumber         String?   @map("part_number")
  product            String?
  vendor             String?
  barcode            String?
  manufacturer       String?
  assetState         String?   @map("asset_state")
  user               String?
  department         String?
  associatedToAssets String?   @map("associated_to_assets")
  site               String?
  region             String?
  location           String?
  isLoanable         Boolean   @default(false) @map("is_loanable")
  loanStart          DateTime? @map("loan_start")
  loanEnd            DateTime? @map("loan_end")
  acquisitionDate    DateTime? @map("acquisition_date")
  expiryDate         DateTime? @map("expiry_date")
  purchaseCost       Float?    @map("purchase_cost")
  warrantyExpiryDate DateTime? @map("warranty_expiry_date")
  purchaseOrder      String?   @map("purchase_order")
  purchaseOrderNo    String?   @map("purchase_order_no")
  lastScanStatus     String?   @map("last_scan_status")
  lastScanTime       DateTime? @map("last_scan_time")
  scanState          String?   @map("scan_state")
  stateComments      String?   @map("state_comments")
  networks           Json?     @default("[]")
  productId          Int?      @map("product_id")
  macAddress         String?   @map("mac_address")
  serviceTag         String?   @map("service_tag")
  domain             String?
  smbiosVersion      String?   @map("smbios_version")
  biosVersion        String?   @map("bios_version")
  biosManufacturer   String?   @map("bios_manufacturer")
  biosDate           String?   @map("bios_date")
  osName             String?   @map("os_name")
  osVersion          String?   @map("os_version")
  osBuildNumber      String?   @map("os_build_number")
  osServicePack      String?   @map("os_service_pack")
  osProductId        String?   @map("os_product_id")
  ram                String?
  virtualMemory      String?   @map("virtual_memory")
  physicalMemory     String?   @map("physical_memory")
  processors         Json?     @default("[]")
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  productType       ProductType             @relation(fields: [productTypeId], references: [id])
  selectedProduct   Product?                @relation("SelectedProduct", fields: [productId], references: [id])
  workstationDetail AssetWorkstationDetail?

  @@map("assets")
}

model AssetWorkstationDetail {
  id                 Int      @id @default(autoincrement())
  assetId            Int      @unique @map("asset_id")
  monitoringProtocol String?  @map("monitoring_protocol")
  lastLoggedInUser   String?  @map("last_logged_in_user")
  biosName           String?  @map("bios_name")
  serviceTag         String?  @map("service_tag")
  biosVersion        String?  @map("bios_version")
  biosManufacturer   String?  @map("bios_manufacturer")
  biosDate           String?  @map("bios_date")
  smbiosVersion      String?  @map("smbios_version")
  domain             String?
  totalMemory        String?  @map("total_memory")
  virtualMemory      String?  @map("virtual_memory")
  logicalProcessors  Int?     @map("logical_processors")
  totalSlots         Int?     @map("total_slots")
  osName             String?  @map("os_name")
  osVersion          String?  @map("os_version")
  osServicePack      String?  @map("os_service_pack")
  osProductId        String?  @map("os_product_id")
  osBuildNumber      String?  @map("os_build_number")
  systemType         String?  @map("system_type")
  licenseType        String?  @map("license_type")
  licenseStatus      String?  @map("license_status")
  systemDrive        String?  @map("system_drive")
  vmPlatform         String?  @map("vm_platform")
  installedVMs       String?  @map("installed_vms")
  allowedVMs         String?  @map("allowed_vms")
  networks           Json?    @default("[]")
  mouseType          String?  @map("mouse_type")
  mouseManufacturer  String?  @map("mouse_manufacturer")
  mouseSerialNumber  String?  @map("mouse_serial_number")
  mouseButtons       String?  @map("mouse_buttons")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  asset        Asset                         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  processors   AssetWorkstationProcessor[]
  hardDisks    AssetWorkstationHardDisk[]
  keyboards    AssetWorkstationKeyboard[]
  monitors     AssetWorkstationMonitor[]
  motherboards AssetWorkstationMotherboard[]

  @@map("asset_workstation_details")
}

model AssetWorkstationProcessor {
  id            Int      @id @default(autoincrement())
  assetDetailId Int      @map("asset_detail_id")
  processorInfo String?  @map("processor_info")
  manufacturer  String?
  clockSpeed    Int?     @map("clock_speed")
  numberOfCores Int?     @map("number_of_cores")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  assetDetail AssetWorkstationDetail @relation(fields: [assetDetailId], references: [id], onDelete: Cascade)

  @@map("asset_workstation_processors")
}

model AssetWorkstationHardDisk {
  id            Int      @id @default(autoincrement())
  assetDetailId Int      @map("asset_detail_id")
  model         String?
  serialNumber  String?  @map("serial_number")
  manufacturer  String?
  capacity      Int?     @map("capacity")
  driveType     String?  @map("drive_type")
  freeSpace     String?  @map("free_space")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  assetDetail AssetWorkstationDetail @relation(fields: [assetDetailId], references: [id], onDelete: Cascade)

  @@map("asset_workstation_hard_disks")
}

model AssetWorkstationKeyboard {
  id            Int      @id @default(autoincrement())
  assetDetailId Int      @map("asset_detail_id")
  keyboardType  String?  @map("keyboard_type")
  manufacturer  String?
  serialNumber  String?  @map("serial_number")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  assetDetail AssetWorkstationDetail @relation(fields: [assetDetailId], references: [id], onDelete: Cascade)

  @@map("asset_workstation_keyboards")
}

model AssetWorkstationMonitor {
  id            Int      @id @default(autoincrement())
  assetDetailId Int      @map("asset_detail_id")
  monitorType   String?  @map("monitor_type")
  serialNumber  String?  @map("serial_number")
  manufacturer  String?
  maxResolution String?  @map("max_resolution")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  assetDetail AssetWorkstationDetail @relation(fields: [assetDetailId], references: [id], onDelete: Cascade)

  @@map("asset_workstation_monitors")
}

model AssetWorkstationMotherboard {
  id            Int       @id @default(autoincrement())
  assetDetailId Int       @map("asset_detail_id")
  product       String?
  model         String?
  version       String?
  partNumber    String?   @map("part_number")
  installedDate DateTime? @map("installed_date")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  assetDetail AssetWorkstationDetail @relation(fields: [assetDetailId], references: [id], onDelete: Cascade)

  @@map("asset_workstation_motherboards")
}
